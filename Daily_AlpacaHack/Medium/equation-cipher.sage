R.<x> = ZZ[]
P = sage_eval(P_raw, locals={'x':x})

factors = P.factor()

flag_dict = {}
for f, _ in factors:
    if f.degree() == 1:
        p = int(f[1])
        c = int(-f[0])
        flag_dict[p] = c

ps = prime_range(200)
flag = "".join([chr(flag_dict[p]) for p in ps if p in flag_dict])
print(f"Flag: {flag}")

